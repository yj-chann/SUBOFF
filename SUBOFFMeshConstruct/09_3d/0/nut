FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

// In LES, the initial internal SGS viscosity is typically zero. 
// It will develop as the flow resolves.
internalField   uniform 0;

boundaryField
{
    INLET1
    {
        // Assumes inflow turbulence is handled by U (e.g., turbulentDigitalFilterInlet)
        type            calculated;
        value           uniform 0;
    }
    INLET2
    {
        type            calculated;
        value           uniform 0;
    }
    OUTLET
    {
        // Zero-gradient allows SGS viscosity to convect out of the domain
        type            zeroGradient;
    }
    HULL
    {
        // --- Option A: Wall-Modeled LES (WMLES) ---
        // Use this if your mesh is relatively coarse near the wall (y+ > 30)
        // type            nutUSpaldingWallFunction;
        // value           uniform 0;
        
        // --- Option B: Wall-Resolved LES (WRLES) ---
        // Use this ONLY if your mesh is extremely fine near the wall (y+ < 1)
        type         fixedValue;
        value        uniform 0;
    }
}

