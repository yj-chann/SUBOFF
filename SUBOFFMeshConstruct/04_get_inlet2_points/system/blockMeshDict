FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


scales 1;

lx 3;
r 60;
nx 3;
ny 900;
nz 640;

vertices
(
    (0 0 0)
	($lx 0 0)
	($lx $r 0)
	(0 $r 0)
	(0 0 $r)
	($lx 0 $r)
	($lx $r $r)
	(0 $r $r)
);

blocks
(
    hex (0   1  2  3  4  5  6  7) ($nx $ny $nz) (1.0 1.0 1.0)
);

edges
(
);

boundary
(

    INLET
    {
        type patch;
        faces
        (
            (3 0 4 7)
        );
    }

    OUTLET
    {
        type wall;
        faces
        (
            (1 0 3 2)
			(2 3 7 6)
			(6 7 4 5)
			(5 4 0 1)
        );
    }

    HULL
    {
        type patch;
        faces
        (
            (6 5 1 2)
        );
    }


);

mergePatchPairs
(
);

