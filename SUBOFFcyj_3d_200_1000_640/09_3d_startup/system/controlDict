 application     pimpleFoam;
 startFrom       startTime;
 startTime       0;
 stopAt          endTime;
 endTime         1.0  ;

  adjustTimeStep  yes;
  maxCo           5;    // Start with 5. If stable, you can push this to 10 or 20.
  maxDeltaT       0.5;  // Set a ceiling for how large the time step can get
  deltaT          2e-4; // Start with a very small step to survive the initial shock

 writeControl    adjustableRunTime;
 writeInterval   0.25 ;
 
 purgeWrite      0;
 writeFormat     ascii;
 writePrecision  14;
 writeCompression off;
 timeFormat      general;
 timePrecision   8;
 runTimeModifiable false;


