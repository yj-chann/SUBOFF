forces
{
    type        forces;

    functionObjectLibs ( "libforces.so" );

    writeControl   timeStep;
    timeInterval    5;

    log         yes;

    patches     (HULL1 HULL2);
    rho         rhoInf;     // Indicates incompressible
    log         true;
    rhoInf      1000;          // Redundant for incompressible

    CofR        (0 0 0);    // Rotation around centre line of propeller
    pitchAxis   (0 0 1);
    liftDir                (0   1    0);
        dragDir            (1    0    0);
      
}
forceCoeffs
{
      type  forceCoeffs;
     functionObjectLibs ( "libforces.so" );
   patches     ( HULL1 HULL2);
    rho         rhoInf;     // Indicates incompressible
    log         true;
    rhoInf      1000;          // Redundant for incompressible

    CofR        (0 0 0);    // Rotation around centre line of propeller
pitchAxis   (0 0 1);
    liftDir                (0   1    0);
        dragDir            (1    0    0);
      magUInf  5.144;
    lRef  4.3561;
    Aref   6.338;

 writeControl   timeStep;
    timeInterval    1;
log         yes;
}
