FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];


internalField   uniform 5.77;

boundaryField
{
    AXIS
    {
        type            empty;
    }
    INLET
    {
        type            fixedValue;
        value           $internalField;
    }
    OUTLET
    {
        type            zeroGradient;
    }
    HULL
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    FRONT
    {
        type            wedge;
    }
    BACK
    {
        type            wedge;
    }
}


