FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains 64;

// method          manual;
//method          hierarchical;
//preservePatches (FRONT BACK);
method          scotch;

hierarchicalCoeffs
{
    n               (1 10 10);
    delta           0.001;
    order           xyz;
}

manualCoeffs
{
    dataFile    "manualDecomposition";
}



