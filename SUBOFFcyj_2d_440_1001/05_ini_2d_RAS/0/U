dimensions      [0 1 -1 0 0 0 0];


internalField   uniform (1.649194 0 0);

boundaryField
{
    AXIS
    {
        type            empty;
    }
    INLET
    {
        type            fixedValue;
        value           uniform (1.649194 0 0);
    }
    OUTLET
    {
        type            inletOutlet;
        inletValue      uniform (0 0 0);
        //value           uniform (18.686868686868689 0 0);
        value           uniform (1.649194 0 0);
    }
    HULL
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    FRONT
    {
        type            wedge;
    }
    BACK
    {
        type            wedge;
    }
}


